# Copy to `.env.local` for local development.

NEXTAUTH_SECRET=generate_a_long_random_string

# Must match the URL you open in the browser (include scheme and port).
NEXTAUTH_URL=http://localhost:3000/

# Base URL of cacsa_app_api — same value used for login (trailing slash OK).
# Example local: http://localhost:5001/
NEXT_PUBLIC_REST_API_ENDPOINT=http://localhost:5001/

# Hymns are loaded via this API; Firebase credentials stay on the API only (firebase.json there).
